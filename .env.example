# Backend selectors — use "fake" until the matching phase is ready.
EMBEDDER_BACKEND=fake
RERANKER_BACKEND=fake
LLM_BACKEND=fake

# Locked model IDs (design doc section 6 — change via config, not scattered code)
EMBEDDER_MODEL=voyage-finance-2
EMBEDDER_DIMENSIONS=1024
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_MODEL=anthropic/claude-haiku-4-5
# Eval-only (Phase 7). Must be a different model family from the generator.
JUDGE_MODEL=REPLACE_WITH_JUDGE_MODEL

# Secrets — leave blank for Phase 0 (fake backends need no keys)
DATABASE_URL=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Generation cap (spend guardrail)
MAX_OUTPUT_TOKENS=1024
